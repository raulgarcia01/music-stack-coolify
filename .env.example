# ─────────────────────────────────────────────
# Variables de entorno para Coolify
# En Coolify: Resource → Environment Variables
# ─────────────────────────────────────────────

# ── yt-dlp Web UI (REQUERIDAS — deploy falla si están vacías) ──
YTDLP_JWT_SECRET=             # genera con: openssl rand -base64 48
YTDLP_USER=admin
YTDLP_PASS=                   # tu password seguro

# ── Navidrome (opcionales, tienen defaults) ──
ND_SCANSCHEDULE=1h
ND_LOGLEVEL=info
ND_SESSIONTIMEOUT=24h
ND_ENABLEINSIGHTSCOLLECTOR=false

# ── Spotify + Last.fm (descomenta cuando los tengas) ──
# ND_SPOTIFY_ID=
# ND_SPOTIFY_SECRET=
# ND_LASTFM_APIKEY=
# ND_LASTFM_SECRET=
