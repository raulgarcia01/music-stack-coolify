# ─────────────────────────────────────────────
# Copia este archivo como .env y llena los valores
# cp .env.example .env
# ─────────────────────────────────────────────

# Navidrome
SERVICE_URL_NAVIDROME=
ND_SCANSCHEDULE=1h
ND_LOGLEVEL=info
ND_SESSIONTIMEOUT=24h
ND_ENABLEINSIGHTSCOLLECTOR=false

# yt-dlp Web UI — ⚠️ Cambia estos valores antes de usar
YTDLP_JWT_SECRET=genera_una_cadena_aleatoria_de_40_caracteres_aqui
YTDLP_USER=admin
YTDLP_PASS=cambia_este_password

# Spotify + Last.fm (descomenta cuando los tengas)
# ND_SPOTIFY_ID=
# ND_SPOTIFY_SECRET=
# ND_LASTFM_APIKEY=
# ND_LASTFM_SECRET=
